# -----------------------------
# Foundry deployment
# -----------------------------
# Deployer private key (0x...)
PRIVATE_KEY=

# Optional explorer API key
ETHERSCAN_API_KEY=

# 已部署的 IXcmNotifier 地址（必填，示例为 2026-03-09 部署）
NOTIFIER_ADDRESS=0xb74411FcD5DB3B3e40f4a3FeE2144eA01E4Dd00e

# 预期 XCM precompile 地址（用于部署前健康检查）
XCM_PRECOMPILE=0x00000000000000000000000000000000000A0000

# 协议参数边界（部署时写入）
MAX_DURATION=31536000
MAX_DEPOSIT_PER_STREAM=1000000000000000000000000000

# -----------------------------
# Frontend runtime
# -----------------------------
NEXT_PUBLIC_RPC_URL=https://services.polkadothub-rpc.com/testnet
NEXT_PUBLIC_CHAIN_ID=420420417

# 部署后的 PolkaStream 合约地址（示例为 2026-03-09 部署）
NEXT_PUBLIC_POLKASTREAM_ADDRESS=0x0Ae8b341F31194DD34f11E075E34e3C266EF4d8D

# 可选：ServicePlan registry 地址（provider-owned commercial plans）
SERVICE_PLAN_REGISTRY_ADDRESS=

# 可选：前端 token 快捷选择，格式：SYMBOL:0xToken1,SYMBOL2:0xToken2
NEXT_PUBLIC_TOKEN_PRESETS=REVUSD:0x1111111111111111111111111111111111111111,USDC:0x2222222222222222222222222222222222222222,DOT:0x3333333333333333333333333333333333333333

# 可选：前端 Ops 页签管理员地址白名单（逗号分隔）
NEXT_PUBLIC_ADMIN_ALLOWLIST=

# -----------------------------
# BFF API (optional)
# -----------------------------
# AI sidecar settlement hub address (UsageSettlementHub)
USAGE_SETTLEMENT_HUB_ADDRESS=

# API server
API_HOST=0.0.0.0
API_PORT=8787
API_AUTH_TOKEN=
SETTLEMENT_WINDOW_SECONDS=30
API_CAST_BIN=cast

# API database (SQLite by default)
API_DB_PATH=services/api/data/polkastream.db
# Or Postgres:
# API_DATABASE_URL=postgresql://user:pass@host:5432/polkastream

# Auth (API Key/JWT)
API_REQUIRE_AUTH=true
API_DEFAULT_TENANT_ID=default
API_KEY_HASH_SALT=
API_JWT_SECRET=
API_JWT_ISSUER=
API_JWT_AUDIENCE=

# Idempotency
API_IDEMPOTENCY_TTL_SECONDS=86400

# Rate limit & circuit breaker
API_RATE_LIMIT_GLOBAL_PER_MIN=0
API_RATE_LIMIT_TENANT_PER_MIN=0
API_CIRCUIT_ERROR_THRESHOLD=20
API_CIRCUIT_WINDOW_SECONDS=60
API_CIRCUIT_COOLDOWN_SECONDS=300

# Risk thresholds
API_MAX_EVENTS_PER_REQUEST=1000
API_MAX_EVENT_AMOUNT_WEI=
API_MAX_TOTAL_AMOUNT_WEI=

# Commercial service trigger operator
# Defaults to PRIVATE_KEY if omitted. Use a dedicated key in production when possible.
STREAM_TRIGGER_PRIVATE_KEY=
# Optional override if you want to expose the operator address without deriving it from the private key.
STREAM_TRIGGER_OPERATOR_ADDRESS=

# Allowlist enforcement
API_ALLOWLIST_ENFORCE=false
API_ALLOWLIST_ENFORCE_KINDS=token,payer,provider

# -----------------------------
# Agent MCP / Skill Adapter (optional)
# -----------------------------
# Direct chain RPC used by services/agent-mcp
POLKASTREAM_MCP_RPC_URL=

# Contract addresses used by services/agent-mcp
POLKASTREAM_MCP_POLKASTREAM_ADDRESS=
POLKASTREAM_MCP_SERVICE_PLAN_REGISTRY_ADDRESS=
POLKASTREAM_MCP_USAGE_SETTLEMENT_HUB_ADDRESS=

# Private key used for direct chain writes from services/agent-mcp
POLKASTREAM_MCP_PRIVATE_KEY=

# API endpoint and auth used by services/agent-mcp for service trigger / settlement tools
POLKASTREAM_MCP_API_BASE_URL=
POLKASTREAM_MCP_API_TOKEN=
